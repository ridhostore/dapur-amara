---
import BaseLayout from '../layouts/BaseLayout.astro';
import MenuCard from '../components/MenuCard.astro';

const menuItems = [
  {
    title: 'Katering Harian',
    description: 'Menu lengkap nasi, lauk hewani dan nabati, sayur, sambal, dan kerupuk. Bisa request menu sesuai selera keluarga. Tersedia paket 2–10 porsi per hari dengan jadwal pengiriman fleksibel.',
    price: 'Mulai Rp 25.000/pax',
    image: '/images/catering-harian.png',
    imageAlt: 'Paket katering harian Dapur Amara dengan nasi dan lauk pauk lengkap',
    waText: 'Halo,%20saya%20ingin%20tanya%20soal%20katering%20harian,%20bisa%20request%20menu?',
  },
  {
    title: 'Snack Box Meeting',
    description: 'Pilihan snack cantik: risoles mayo, pastel sayur, kue lapis, lemper, dan mini sandwich. Cocok untuk rapat kantor, seminar, workshop, atau acara komunitas.',
    price: 'Mulai Rp 20.000/box',
    image: '/images/snack-box.png',
    imageAlt: 'Snack box meeting Dapur Amara dengan aneka kue dan camilan',
    waText: 'Saya%20butuh%20snack%20box%20untuk%20meeting,%20bisa%20dibantu%20detailnya?',
  },
  {
    title: 'Nasi Box Hajatan',
    description: 'Paket lengkap nasi, rendang/ayam, sayur, telur, buah potong, dan kerupuk dalam kotak karton food grade. Ideal untuk arisan, syukuran, pengajian, atau acara keluarga.',
    price: 'Mulai Rp 30.000/box',
    image: '/images/nasi-box.png',
    imageAlt: 'Nasi box hajatan Dapur Amara untuk acara dan syukuran',
    waText: 'Info%20nasi%20box%20hajatan%20ya,%20terima%20kasih.',
  },
];
---

<BaseLayout
  title="Menu & Harga – Dapur Amara Katering Jakarta Selatan"
  description="Lihat pilihan paket katering harian, snack box meeting, dan nasi box hajatan dari Dapur Amara. Harga terjangkau, menu bisa disesuaikan."
>
  <!-- Page Header -->
  <section class="section-padding" style="background-color: var(--color-cream);" id="menu-header">
    <div class="container text-center">
      <h1 class="mb-4" style="font-family: var(--font-heading);">Menu &amp; Pilihan Paket</h1>
      <p class="max-w-2xl mx-auto" style="color: var(--color-text-secondary);">
        Harga yang tercantum adalah estimasi. Silakan hubungi kami untuk penawaran terbaik sesuai kebutuhan Anda.
      </p>
    </div>
  </section>

  <!-- Menu Cards -->
  <section class="section-padding bg-white" id="menu-cards">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        {menuItems.map(item => (
          <MenuCard {...item} />
        ))}
      </div>

      <!-- Additional Info -->
      <div class="mt-12 p-6 rounded-xl text-center" style="background-color: var(--color-cream);" id="menu-note">
        <p class="flex items-center justify-center gap-2 text-sm" style="color: var(--color-text-secondary);">
          <svg class="w-5 h-5 shrink-0" style="color: var(--color-sage);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
          Menu dapat disesuaikan. Hubungi kami untuk opsi diet khusus atau request menu tertentu.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
