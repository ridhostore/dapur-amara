---
const services = [
  {
    title: 'Katering Harian',
    description: 'Menu lengkap lauk pauk rumahan, bisa request sesuai selera keluarga. Mulai dari 2 porsi per hari.',
    icon: 'utensils',
    waText: 'Halo,%20saya%20ingin%20tanya%20soal%20katering%20harian,%20bisa%20request%20menu?',
  },
  {
    title: 'Snack Box Meeting',
    description: 'Pilihan snack cantik dan mengenyangkan untuk rapat kantor, seminar, atau acara komunitas.',
    icon: 'box',
    waText: 'Saya%20butuh%20snack%20box%20untuk%20meeting,%20bisa%20dibantu%20detailnya?',
  },
  {
    title: 'Nasi Box Hajatan',
    description: 'Praktis, lengkap dengan nasi, lauk, sayur, buah, dan kerupuk. Cocok untuk arisan atau syukuran.',
    icon: 'gift',
    waText: 'Info%20nasi%20box%20hajatan%20ya,%20terima%20kasih.',
  },
];
---

<section class="section-padding" style="background-color: var(--color-cream);" id="layanan-section">
  <div class="container">
    <h2 class="text-center mb-12" style="font-family: var(--font-heading); color: var(--color-text);">Layanan Kami</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
      {services.map((service, i) => (
        <div class="card p-6 md:p-8 text-center flex flex-col items-center" id={`service-card-${i}`}>
          <!-- Icon -->
          {service.icon === 'utensils' && (
            <div class="w-16 h-16 rounded-full flex items-center justify-center mb-5" style="background-color: rgba(122, 157, 109, 0.1);">
              <svg class="w-8 h-8" style="color: var(--color-sage);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>
            </div>
          )}
          {service.icon === 'box' && (
            <div class="w-16 h-16 rounded-full flex items-center justify-center mb-5" style="background-color: rgba(122, 157, 109, 0.1);">
              <svg class="w-8 h-8" style="color: var(--color-sage);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
            </div>
          )}
          {service.icon === 'gift' && (
            <div class="w-16 h-16 rounded-full flex items-center justify-center mb-5" style="background-color: rgba(122, 157, 109, 0.1);">
              <svg class="w-8 h-8" style="color: var(--color-sage);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="4" rx="1"/><path d="M12 8v13"/><path d="M19 12v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-7"/><path d="M7.5 8a2.5 2.5 0 0 1 0-5A4.8 8 0 0 1 12 8a4.8 8 0 0 1 4.5-5 2.5 2.5 0 0 1 0 5"/></svg>
            </div>
          )}
          <h3 class="mb-3" style="font-family: var(--font-heading); color: var(--color-text);">{service.title}</h3>
          <p class="text-sm leading-relaxed mb-5" style="color: var(--color-text-secondary);">{service.description}</p>
          <a href={`https://wa.me/6289668042294?text=${service.waText}`} target="_blank" rel="noopener" class="mt-auto text-sm font-semibold underline underline-offset-4 decoration-1 transition-smooth hover:decoration-2" style="color: var(--color-sage-dark);">
            Pesan Sekarang →
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
