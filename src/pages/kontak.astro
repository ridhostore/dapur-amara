---
import BaseLayout from '../layouts/BaseLayout.astro';

const waLink = 'https://wa.me/6289668042294?text=Halo%20Dapur%20Amara,%20saya%20tertarik%20dengan%20katering.%20Bisa%20minta%20info%20lengkap?';

const steps = [
  { num: '1', title: 'Pilih Paket', desc: 'Pilih paket atau request menu via WhatsApp.' },
  { num: '2', title: 'Konfirmasi', desc: 'Konfirmasi jumlah porsi & alamat pengiriman.' },
  { num: '3', title: 'Pembayaran', desc: 'Pembayaran COD atau transfer bank.' },
  { num: '4', title: 'Diantar Hangat', desc: 'Pesanan diantar hangat ke lokasi Anda.' },
];
---

<BaseLayout
  title="Kontak & Cara Pesan – Dapur Amara Katering Jakarta Selatan"
  description="Hubungi Dapur Amara untuk pesan katering. Cara pesan mudah via WhatsApp. Lokasi di Kebayoran Baru, Jakarta Selatan."
>
  <!-- Page Header -->
  <section class="section-padding" style="background-color: var(--color-cream);" id="kontak-header">
    <div class="container text-center">
      <h1 class="mb-4" style="font-family: var(--font-heading);">Hubungi Kami &amp; Cara Pesan</h1>
      <p style="color: var(--color-text-secondary);">Pesan mudah, cepat, dan langsung via WhatsApp.</p>
    </div>
  </section>

  <!-- Main Content -->
  <section class="section-padding bg-white" id="kontak-content">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16">
        <!-- Left: How to Order -->
        <div>
          <h2 class="text-xl mb-8" style="font-family: var(--font-heading);">Cara Pesan</h2>
          <div class="space-y-6 mb-10">
            {steps.map(step => (
              <div class="flex items-start gap-4" id={`step-${step.num}`}>
                <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0 text-white font-bold text-sm" style="background-color: var(--color-sage); font-family: var(--font-heading);">
                  {step.num}
                </div>
                <div class="pt-1.5">
                  <h3 class="text-base font-semibold mb-1" style="font-family: var(--font-heading); color: var(--color-text);">{step.title}</h3>
                  <p class="text-sm" style="color: var(--color-text-secondary);">{step.desc}</p>
                </div>
              </div>
            ))}
          </div>
          <a href={waLink} target="_blank" rel="noopener" class="btn-wa text-base px-8 py-4" id="kontak-wa-btn">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.116.553 4.104 1.519 5.834L0 24l6.335-1.652A11.943 11.943 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.82c-1.92 0-3.748-.508-5.37-1.457l-.385-.228-3.997 1.046 1.07-3.898-.251-.398A9.818 9.818 0 012.18 12c0-5.404 4.416-9.82 9.82-9.82 5.404 0 9.82 4.416 9.82 9.82 0 5.404-4.416 9.82-9.82 9.82z"/></svg>
            Pesan via WhatsApp
          </a>
        </div>

        <!-- Right: Map & Contact Info -->
        <div>
          <h2 class="text-xl mb-8" style="font-family: var(--font-heading);">Lokasi Kami</h2>
          <div class="rounded-xl overflow-hidden mb-6 shadow-sm" id="map-container">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3966.1!2d106.7835!3d-6.2443!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNsKwMTQnMzkuNSJTIDEwNsKwNDcnMDAuNiJF!5e0!3m2!1sid!2sid!4v1"
              width="100%"
              height="300"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Lokasi Dapur Amara di Google Maps"
            ></iframe>
          </div>
          <div class="space-y-3 text-sm" style="color: var(--color-text-secondary);">
            <p class="flex items-start gap-3">
              <svg class="w-5 h-5 shrink-0 mt-0.5" style="color: var(--color-sage);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Jl. Melati No. 12, Kebayoran Baru, Jakarta Selatan
            </p>
            <p class="flex items-start gap-3">
              <svg class="w-5 h-5 shrink-0 mt-0.5" style="color: var(--color-sage);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              +62 896-6804-2294 (WhatsApp)
            </p>
            <p class="flex items-start gap-3">
              <svg class="w-5 h-5 shrink-0 mt-0.5" style="color: var(--color-sage);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              info@dapuramara.id
            </p>
            <p class="flex items-start gap-3">
              <svg class="w-5 h-5 shrink-0 mt-0.5" style="color: var(--color-sage);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              Senin–Sabtu, 08.00–16.00
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cross-sell Section -->
  <section class="section-padding" style="background-color: var(--color-cream);" id="crosssell-section">
    <div class="container text-center max-w-2xl">
      <h2 class="text-xl mb-4" style="font-family: var(--font-heading);">Punya usaha dan ingin website seperti ini?</h2>
      <p class="mb-6 text-sm leading-relaxed" style="color: var(--color-text-secondary);">
        Website ini dibuat oleh <strong>RidhoWebs</strong>. Kami siap bantu UMKM Anda tampil online profesional, dengan harga terjangkau.
      </p>
      <a
        href="https://ridhowebs.biz.id"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-semibold text-sm text-white transition-smooth hover:opacity-90"
        style="background-color: var(--color-sage); font-family: var(--font-heading);"
        id="crosssell-btn"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        Kunjungi RidhoWebs
      </a>
    </div>
  </section>
</BaseLayout>
