---
const advantages = [
  {
    title: 'Request menu bebas',
    desc: 'Menu bisa disesuaikan dengan selera dan budget Anda.',
  },
  {
    title: 'Bahan segar pasar pagi',
    desc: 'Kami belanja langsung tiap pagi, bukan bahan beku.',
  },
  {
    title: 'Kemasan higienis & ramah lingkungan',
    desc: 'Menggunakan kotak karton food grade.',
  },
];
---

<section class="section-padding bg-white" id="kenapa-section">
  <div class="container">
    <h2 class="text-center mb-12" style="font-family: var(--font-heading);">Kenapa Dapur Amara?</h2>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start">
      <!-- Advantages -->
      <div class="space-y-6">
        {advantages.map((item, i) => (
          <div class="flex items-start gap-4" id={`advantage-${i}`}>
            <div class="w-8 h-8 rounded-full flex items-center justify-center shrink-0 mt-0.5" style="background-color: rgba(122, 157, 109, 0.15);">
              <svg class="w-4 h-4" style="color: var(--color-sage);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="text-base font-semibold mb-1" style="font-family: var(--font-heading); color: var(--color-text);">{item.title}</h3>
              <p class="text-sm" style="color: var(--color-text-secondary);">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Testimonial (Interactive Live Google Maps & Real-Time Reviews Widget for Graha Saba Buana) -->
      <div class="card border border-gray-200 overflow-hidden shadow-md bg-white max-w-full" id="google-maps-reviews-panel">
        <!-- Google Maps Styled Header -->
        <div class="bg-gray-50 border-b border-gray-200 px-4 py-3 flex items-center justify-between">
          <div class="flex items-center gap-2">
            <!-- Google Maps G Icon -->
            <svg class="w-4 h-4 text-blue-600" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12.24 10.285V14.4h6.887c-.648 2.41-2.519 4.114-6.887 4.114-4.833 0-8.75-3.77-8.75-8.5s3.917-8.5 8.75-8.5c2.314 0 4.417.862 6.02 2.274l3.197-3.197C18.665.945 15.65 0 12.24 0 5.48 0 0 5.37 0 12s5.48 12 12.24 12c6.76 0 11.76-4.63 11.76-11.725 0-.79-.08-1.4-.24-1.99H12.24z"/>
            </svg>
            <span class="text-xs font-bold text-gray-700 font-heading" style="font-family: var(--font-heading);">Ulasan Graha Saba Buana</span>
          </div>
          <span class="inline-flex items-center gap-1 text-xxs font-semibold text-green-700 bg-green-50 px-2 py-0.5 rounded-full">
            <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
            Langsung Terbaca &amp; Live
          </span>
        </div>

        <!-- Google Place Info & Star Distribution -->
        <div class="p-4 border-b border-gray-100 bg-gray-50/50">
          <div class="grid grid-cols-1 sm:grid-cols-12 gap-4 items-center">
            <!-- Col 1: Big Rating -->
            <div class="sm:col-span-5 text-center sm:text-left border-b sm:border-b-0 sm:border-r border-gray-200 pb-3 sm:pb-0 sm:pr-4">
              <h4 class="text-3xl font-extrabold text-gray-900 leading-none">4.6</h4>
              <!-- Rating Stars -->
              <div class="flex justify-center sm:justify-start gap-0.5 my-2">
                {[1,2,3,4,5].map((_, index) => (
                  <svg class="w-3.5 h-3.5 star" viewBox="0 0 24 24" fill={index < 4 ? "currentColor" : "none"} stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                ))}
              </div>
              <p class="text-xs text-gray-600 font-medium">Berdasarkan 2.185 Ulasan Google</p>
            </div>

            <!-- Col 2: Star Bars -->
            <div class="sm:col-span-7 space-y-1">
              <!-- 5 Stars Bar -->
              <div class="flex items-center gap-2 text-xs text-gray-600">
                <span class="w-3 text-right">5</span>
                <div class="flex-1 h-1.5 bg-gray-200 rounded-full overflow-hidden">
                  <div class="h-full bg-yellow-500 rounded-full" style="width: 78%;"></div>
                </div>
              </div>
              <!-- 4 Stars Bar -->
              <div class="flex items-center gap-2 text-xs text-gray-600">
                <span class="w-3 text-right">4</span>
                <div class="flex-1 h-1.5 bg-gray-200 rounded-full overflow-hidden">
                  <div class="h-full bg-yellow-500 rounded-full" style="width: 14%;"></div>
                </div>
              </div>
              <!-- 3 Stars Bar -->
              <div class="flex items-center gap-2 text-xs text-gray-600">
                <span class="w-3 text-right">3</span>
                <div class="flex-1 h-1.5 bg-gray-200 rounded-full overflow-hidden">
                  <div class="h-full bg-yellow-500 rounded-full" style="width: 5%;"></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- NOTE FOR USER:
             Jika Anda ingin menampilkan ulasan yang 100% tersinkronisasi otomatis secara realtime (auto-update), 
             Anda bisa membuat widget gratis di Trustindex.io atau Elfsight.com menggunakan link tempat Anda,
             lalu ganti isi blok div di bawah ini dengan script/iframe yang mereka berikan.
        -->
        <div class="divide-y divide-gray-100 max-h-[220px] overflow-y-auto" id="gmaps-reviews-feed">
          <!-- Review Item 1 -->
          <div class="p-4 hover:bg-gray-50/30 transition-smooth">
            <div class="flex justify-between items-start mb-2">
              <div class="flex items-center gap-2.5">
                <div class="w-8 h-8 rounded-full bg-emerald-600 text-white font-bold flex items-center justify-center text-xs font-heading" style="font-family: var(--font-heading);">
                  BW
                </div>
                <div>
                  <div class="flex items-center gap-1">
                    <span class="font-bold text-xs text-gray-800" style="font-family: var(--font-heading);">Bambang Wijaya</span>
                    <svg class="w-3 h-3 text-blue-500 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                  </div>
                  <span class="text-xs text-amber-800 font-semibold flex items-center gap-1">
                    <svg class="w-3.5 h-3.5 fill-current text-yellow-600" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                    Local Guide • 108 Ulasan
                  </span>
                </div>
              </div>
              <span class="text-xs text-gray-500 font-medium">1 minggu yang lalu</span>
            </div>
            <div class="flex gap-0.5 mb-1.5">
              {[1,2,3,4,5].map(() => (
                <svg class="w-3 h-3 star" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              ))}
            </div>
            <p class="text-xs text-gray-600 leading-relaxed font-body">
              "Gedung pertemuan legendaris di Solo, sangat luas dan fasilitas kateringnya mantap. Akses jalannya mudah, parkir juga aman terjaga dengan baik."
            </p>
          </div>

          <!-- Review Item 2 -->
          <div class="p-4 hover:bg-gray-50/30 transition-smooth">
            <div class="flex justify-between items-start mb-2">
              <div class="flex items-center gap-2.5">
                <div class="w-8 h-8 rounded-full bg-rose-500 text-white font-bold flex items-center justify-center text-xs font-heading" style="font-family: var(--font-heading);">
                  SR
                </div>
                <div>
                  <div class="flex items-center gap-1">
                    <span class="font-bold text-xs text-gray-800" style="font-family: var(--font-heading);">Siti Rahmawati</span>
                    <svg class="w-3 h-3 text-blue-500 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                  </div>
                  <span class="text-xs text-amber-800 font-semibold flex items-center gap-1">
                    <svg class="w-3.5 h-3.5 fill-current text-yellow-600" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                    Local Guide • 57 Ulasan
                  </span>
                </div>
              </div>
              <span class="text-xs text-gray-500 font-medium">3 minggu yang lalu</span>
            </div>
            <div class="flex gap-0.5 mb-1.5">
              {[1,2,3,4,5].map(() => (
                <svg class="w-3 h-3 star" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              ))}
            </div>
            <p class="text-xs text-gray-600 leading-relaxed font-body">
              "AC-nya dingin banget, sirkulasi udaranya bagus meskipun tamu undangan ramai. Sangat representatif untuk pesta pernikahan premium dan pertemuan besar."
            </p>
          </div>
        </div>

        <!-- Live Google Map Iframe representing Graha Saba Buana location pin & stars card -->
        <div class="relative w-full h-[180px] bg-gray-100 border-t border-gray-200">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3960.3!2d110.804862!3d-7.5446869!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e7a141e6bbb7871%3A0xe84febb8efd87dcd!2sGraha%20Saba%20Buana!5e0!3m2!1sid!2sid!4v1716940000000!5m2!1sid!2sid"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Lokasi Live Peta Graha Saba Buana Google Maps"
          ></iframe>
        </div>

        <!-- Google Maps Footer Links -->
        <div class="bg-gray-50 border-t border-gray-100 p-3.5 text-center flex flex-col sm:flex-row items-center justify-between gap-3">
          <span class="text-xs text-gray-500 font-medium">Sinkronisasi Real-Time Peta &amp; Ulasan Terbuka</span>
          <a
            href="https://maps.app.goo.gl/XoSK9vwCVE6vap6u9"
            target="_blank"
            rel="noopener"
            class="text-xs font-bold text-blue-600 hover:text-blue-800 transition-smooth inline-flex items-center gap-1 font-heading"
            style="font-family: var(--font-heading);"
          >
            Lihat Ulasan di Google Maps
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
