---
const waLink = 'https://wa.me/6289668042294?text=Halo%20Dapur%20Amara,%20saya%20tertarik%20dengan%20katering.%20Bisa%20minta%20info%20lengkap?';
---

<section class="relative min-h-[70vh] md:min-h-[80vh] flex items-center justify-center overflow-hidden" id="hero-section">
  <div class="absolute inset-0 hero-parallax">
    <img src="/images/hero.png" alt="Hidangan katering rumahan Dapur Amara" class="w-full h-full object-cover" loading="eager" decoding="async" width="1200" height="675" />
    <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.2) 50%, rgba(0,0,0,0.1) 100%);"></div>
  </div>
  <div class="relative z-10 container text-center text-white px-4 py-16 md:py-24">
    <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold mb-4 text-white leading-tight drop-shadow-lg" style="font-family: var(--font-heading);">Katering Rumahan Sehat &amp; Lezat</h1>
    <p class="text-lg md:text-xl text-white/90 mb-2 font-medium drop-shadow" style="font-family: var(--font-heading);">Menu harian, snack box kantor, dan nasi box arisan – <span class="text-white">Dapur Amara</span></p>
    <div class="space-y-1 mb-8">
      <p class="text-sm md:text-base text-white/80">🚚 Dikirim hangat ke area Jakarta Selatan</p>
      <p class="text-sm md:text-base text-white/80">🌿 Pesan sekarang, kami siapkan dengan bahan segar pagi hari</p>
    </div>
    <a href={waLink} target="_blank" rel="noopener" class="btn-wa text-base md:text-lg px-8 py-4 shadow-lg" id="hero-cta-btn">
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.116.553 4.104 1.519 5.834L0 24l6.335-1.652A11.943 11.943 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.82c-1.92 0-3.748-.508-5.37-1.457l-.385-.228-3.997 1.046 1.07-3.898-.251-.398A9.818 9.818 0 012.18 12c0-5.404 4.416-9.82 9.82-9.82 5.404 0 9.82 4.416 9.82 9.82 0 5.404-4.416 9.82-9.82 9.82z"/></svg>
      Pesan via WhatsApp
