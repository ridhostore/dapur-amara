---
interface Props {
  title: string;
  description: string;
  price: string;
  image: string;
  imageAlt: string;
  waText: string;
}

const { title, description, price, image, imageAlt, waText } = Astro.props;
const waLink = `https://wa.me/6289668042294?text=${waText}`;
---

<div class="card flex flex-col" id={`menu-card-${title.toLowerCase().replace(/\s+/g, '-')}`}>
  <div class="h-48 md:h-52 overflow-hidden">
    <img src={image} alt={imageAlt} class="w-full h-full object-cover transition-transform duration-300 hover:scale-105" loading="lazy" decoding="async" width="400" height="208" />
  </div>
  <div class="p-6 flex flex-col flex-1">
    <h3 class="mb-2" style="font-family: var(--font-heading); color: var(--color-text);">{title}</h3>
    <p class="text-sm leading-relaxed mb-4 flex-1" style="color: var(--color-text-secondary);">{description}</p>
    <p class="text-lg font-bold mb-4" style="font-family: var(--font-heading); color: var(--color-sage-dark);">{price}</p>
    <a href={waLink} target="_blank" rel="noopener" class="btn-wa justify-center text-sm py-3" id={`menu-wa-${title.toLowerCase().replace(/\s+/g, '-')}`}>
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.116.553 4.104 1.519 5.834L0 24l6.335-1.652A11.943 11.943 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.82c-1.92 0-3.748-.508-5.37-1.457l-.385-.228-3.997 1.046 1.07-3.898-.251-.398A9.818 9.818 0 012.18 12c0-5.404 4.416-9.82 9.82-9.82 5.404 0 9.82 4.416 9.82 9.82 0 5.404-4.416 9.82-9.82 9.82z"/></svg>
      Tanya &amp; Pesan via WhatsApp
    </a>
  </div>
</div>
