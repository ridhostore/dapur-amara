---
// FAQAccordion.astro
const faqs = [
  {
    q: "Apakah makanan dijamin Halal?",
    a: "Ya, 100% Halal. Seluruh bahan makanan, bumbu, serta proses pengolahan kami terjamin kebersihan dan kehalalannya."
  },
  {
    q: "Bagaimana sistem pengiriman makanannya?",
    a: "Makanan dimasak segar di pagi hari dan dikirim menggunakan armada khusus agar tetap hangat sampai di meja Anda sebelum jam makan siang (estimasi tiba pukul 10.30 - 12.00 WIB)."
  },
  {
    q: "Apakah bisa request menu/diet tertentu?",
    a: "Tentu saja! Anda bisa request menu bebas MSG, rendah garam, diet karbohidrat, atau menghindari alergen tertentu. Silakan hubungi kami via WhatsApp untuk penyesuaian khusus."
  },
  {
    q: "Berapa minimal pemesanan untuk katering harian?",
    a: "Minimal pemesanan untuk katering harian adalah 2 porsi per hari, sangat cocok untuk bekal suami-istri, saudara, maupun bekal kantor pribadi."
  },
  {
    q: "Bagaimana cara melakukan pembayaran?",
    a: "Kami menerima pembayaran melalui transfer Bank Mandiri, BCA, serta pembayaran cash di tempat (COD) untuk pesanan pertama atau pelanggan mingguan/bulanan."
  }
];
---

<section class="section-padding bg-cream/40 border-t border-b border-cream-dark" id="faq-section">
  <div class="container max-w-3xl">
    <div class="text-center mb-10">
      <h2 class="mb-3" style="font-family: var(--font-heading);">Pertanyaan Umum (FAQ)</h2>
      <p class="text-sm text-gray-500">Hal-hal yang sering ditanyakan pelanggan Dapur Amara.</p>
    </div>

    <div class="card overflow-hidden border border-cream-dark" id="accordion-group">
      {faqs.map((faq, i) => (
        <div class="accordion-item" id={`faq-item-${i}`}>
          <button class="accordion-header" aria-expanded="false" aria-controls={`faq-content-${i}`}>
            <span class="font-heading font-semibold text-sm md:text-base pr-4 text-gray-800" style="font-family: var(--font-heading);">
              {faq.q}
            </span>
            <!-- Plus/Minus Animated Icon -->
            <svg class="w-5 h-5 shrink-0 text-sage accordion-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div id={`faq-content-${i}`} class="accordion-content" role="region">
            <p class="text-sm text-gray-600 leading-relaxed">
              {faq.a}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  function initAccordion() {
    const items = document.querySelectorAll('.accordion-item');

    items.forEach(item => {
      const header = item.querySelector('.accordion-header');
      const content = item.querySelector('.accordion-content') as HTMLDivElement;

      if (!header || !content) return;

      header.addEventListener('click', () => {
        const isOpen = header.getAttribute('aria-expanded') === 'true';

        // Close all other items
        items.forEach(otherItem => {
          if (otherItem !== item) {
            const otherHeader = otherItem.querySelector('.accordion-header');
            const otherContent = otherItem.querySelector('.accordion-content') as HTMLDivElement;
            if (otherHeader && otherContent) {
              otherHeader.setAttribute('aria-expanded', 'false');
              otherContent.style.maxHeight = '0';
              otherContent.classList.remove('open');
              otherItem.classList.remove('active');
            }
          }
        });

        // Toggle current item
        header.setAttribute('aria-expanded', String(!isOpen));
        if (!isOpen) {
          content.style.maxHeight = content.scrollHeight + 'px';
          content.classList.add('open');
          item.classList.add('active');
        } else {
          content.style.maxHeight = '0';
          content.classList.remove('open');
          item.classList.remove('active');
        }
      });
    });
  }

  // Bind on load
  initAccordion();

  // Bind on Astro transitions
  document.addEventListener('astro:after-swap', initAccordion);
</script>
